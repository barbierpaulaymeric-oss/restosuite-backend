# ═══════════════════════════════════════════════════════════════
# RestoSuite — Environment variables reference
# ───────────────────────────────────────────────────────────────
# Copy to `.env` in the project root (or `server/.env`) and fill
# in real values. Never commit the real `.env` file.
# ═══════════════════════════════════════════════════════════════

# ─── Runtime ─────────────────────────────────────────────
NODE_ENV=production                         # 'production' | 'development' | 'test'
PORT=3000                                   # HTTP port for the Express server

# ─── Persistence ─────────────────────────────────────────
# Absolute path to the SQLite database file. In production on Render, leave
# unset — the server falls back to /data/restosuite.db when /data exists.
# For tests the helper forces ':memory:'.
DB_PATH=

# ─── Authentication ─────────────────────────────────────
# REQUIRED in production. Must be ≥32 chars. Generate with:
#   openssl rand -base64 48
# The same secret is used to sign JWTs and derive the CSRF HMAC.
JWT_SECRET=change-me-to-a-32-plus-character-random-string

# ─── AI (Gemini) ─────────────────────────────────────────
# Used by /api/ai/* routes and analytics summarisation. Without a key the
# server degrades gracefully to deterministic fallbacks.
GEMINI_API_KEY=

# Per-user and per-tenant AI rate limits (requests/hour). Optional — defaults
# below are applied in server/routes/ai-core.js.
AI_LIMIT_ACCOUNT_HOUR=60
AI_LIMIT_TENANT_HOUR=300

# ─── Stripe ──────────────────────────────────────────────
# Server-side secret key, webhook signing secret, and the Price ID used by
# POST /api/stripe/create-checkout. When STRIPE_SECRET_KEY is empty, paid
# plans are disabled and checkout endpoints return 503.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
# Client-side publishable key, injected into the frontend at build/serve time.
STRIPE_PUBLISHABLE_KEY=pk_live_...

# ─── Admin access ────────────────────────────────────────
# Comma-separated emails allowed into /admin/*. In production the server
# fails closed on boot if this is unset.
ADMIN_EMAILS=ops@example.com,founder@example.com

# ─── Observability (Sentry) ─────────────────────────────
# Optional. When unset the tracker no-ops.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# ─── Transactional email (SMTP) ─────────────────────────
# Reserved for password-reset / invite / alert emails. Not currently consumed
# by runtime code — leave blank until the mailer is wired up.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=no-reply@restosuite.fr

# ─── Public URL ─────────────────────────────────────────
# Base URL used in outbound links (invites, reset emails, Stripe redirect).
# Not currently consumed by runtime code — leave blank until needed.
APP_URL=https://app.restosuite.fr

# ─── Render-specific (auto-populated on Render) ─────────
# RENDER=true
# RENDER_EXTERNAL_URL=https://restosuite-backend.onrender.com

# ─── Test-only ──────────────────────────────────────────
# Set LOG_IN_TEST=1 to keep logger output visible during `npm test`.
# LOG_IN_TEST=0
